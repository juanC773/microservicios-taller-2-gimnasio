{
  "info": {
    "name": "Microservicios Gimnasio - Newman",
    "description": "Colección completa: todos los endpoints, happy path (rol correcto), unhappy path (rol incorrecto 403, sin token 401). Incluye Auth, Health, Miembros, Clases, Entrenadores, Equipos, Notificaciones (y DLQ: simular-pago + pagos-fallidos). Client secret en environment. Ejecutar: newman run <coleccion> -e Gimnasio.postman_environment.json",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "0 - Auth",
      "item": [
        {
          "name": "Token admin1",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Token admin1 - Status 200', function() { pm.response.to.have.status(200); });",
                  "const json = pm.response.json();",
                  "pm.test('Tiene access_token', function() { pm.expect(json).to.have.property('access_token'); });",
                  "if (json.access_token) pm.environment.set('token_admin1', json.access_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/x-www-form-urlencoded"}],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {"key": "grant_type", "value": "password"},
                {"key": "client_id", "value": "{{client_id}}"},
                {"key": "client_secret", "value": "{{client_secret}}"},
                {"key": "username", "value": "{{admin_username}}"},
                {"key": "password", "value": "{{admin_password}}"}
              ]
            },
            "url": "{{keycloak_url}}/realms/{{keycloak_realm}}/protocol/openid-connect/token"
          }
        },
